rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ FASE 0: Estas reglas se reescribieron para cubrir las colecciones REALES de la
    // app y cerrar agujeros (ver docs/wala/FASE-0-SEGURIDAD.md, H-06/H-07/H-08/H-09).
    // ANTES DE DESPLEGAR A PRODUCCIÓN: comparar con las reglas actualmente desplegadas en
    // la consola (pueden ser más permisivas que el repo) y probar en el Rules Playground /
    // staging. Cualquier colección NO listada aquí queda DENEGADA por defecto.

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // Admin = custom claim `admin: true` (fuente de verdad, H-09) o, como puente de
    // bootstrap, doc adminUsers/{uid} con role 'admin'. Meta: depender solo del claim.
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        (exists(/databases/$(database)/documents/adminUsers/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/adminUsers/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // Campos sensibles que el propio usuario NUNCA puede auto-modificar (H-06).
    // Todo earn/spend de estos campos se hace SOLO desde Cloud Functions
    // (feedKapiSecure, spendCoinsSecure, spinRuletaSecure, etc.). NOTA: requiere
    // que esas Functions estén desplegadas ANTES de publicar estas reglas, o se
    // romperán juegos/recompensas. 'referralCode'/'referralCodeEdited'/'lastAppOpen'
    // NO se bloquean porque el cliente los escribe legítimamente.
    function camposSaldo() {
      return [
        'monedas', 'monedasReclamadas', 'monedasEnEspera', 'historialMonedasEspera', 'role',
        'monedasActivas', 'kapiCoins', 'kapiHappiness', 'lastKapiClaimDate', 'weeklyClaimsData',
        'activeMultiplier', 'multiplierExpiresAt', 'weeklyChallengeProgress',
        'lastBallSortReward', 'lastRuletaSpinWeek', 'streakBonusReceived', 'surveyRewardClaimed',
        'referralOrdersClaimed',
        // Fase 2 (fidelización): los escribe SOLO el servidor (dailyCheckInSecure,
        // completeMissionSecure). El cliente nunca puede auto-modificar XP/racha/check-in.
        'xp', 'dailyStreak', 'lastCheckInDate',
        // Fase 5 (fidelización): los escribe SOLO el servidor (openDailyChestSecure,
        // computeSegmentsSecure). El cliente nunca puede auto-modificar cofre/segmento.
        'segment', 'lastChestDate'
      ];
    }
    function noTocaCamposSensibles() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(camposSaldo());
    }
    // H-06 #4: en la CREACIÓN del perfil tampoco se pueden incluir campos de saldo
    // (setDoc(merge:true) dispara create cuando el doc aún no existe).
    function sinSaldoEnCreate() {
      return !request.resource.data.keys().hasAny(camposSaldo());
    }
    // H-06 #3: el DNI solo puede fijarse cuando está vacío; una vez puesto es inmutable
    // para el propio usuario (evita "cosechar" pedidos ajenos cambiando el DNI).
    function dniInmutable() {
      return resource.data.dni == null || request.resource.data.dni == resource.data.dni;
    }

    // ── Catálogo y taxonomías (lectura pública, escritura admin) ─────────────────
    match /productos_wala/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /tienda_categories/{id}     { allow read: if true; allow write: if isAdmin(); }
    match /tienda_collections/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /tienda_brands/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /tienda_mockups/{id}        { allow read: if true; allow write: if isAdmin(); }
    match /tienda_themes/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /tienda_landing_pages/{id}  { allow read: if true; allow write: if isAdmin(); }
    match /pages/{id}                 { allow read: if true; allow write: if isAdmin(); }
    match /landingPages/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /productTypes/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /tags/{id}                  { allow read: if true; allow write: if isAdmin(); }
    match /characters/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /cliparts/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /customShapes/{id}          { allow read: if true; allow write: if isAdmin(); }
    match /fonts/{id}                 { allow read: if true; allow write: if isAdmin(); }
    match /templates/{id}             { allow read: if true; allow write: if isAdmin(); }
    match /vendors/{id}               { allow read: if true; allow write: if isAdmin(); }
    match /niches/{id}                { allow read: if true; allow write: if isAdmin(); }
    match /blueprints/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /storefront/{id}            { allow read: if true; allow write: if isAdmin(); }
    match /storeConfig/{id}           { allow read: if true; allow write: if isAdmin(); }
    match /configuracion/{id}         { allow read: if true; allow write: if isAdmin(); }
    match /settings/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /messages/{id}              { allow read: if true; allow write: if isAdmin(); }
    match /suggested_packages/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /universal_dates/{id}       { allow read: if true; allow write: if isAdmin(); }
    match /tienda_encuesta_config/{id}{ allow read: if true; allow write: if isAdmin(); }
    match /cuestionarios_templates/{id}{ allow read: if true; allow write: if isAdmin(); }

    // Compat: colecciones legacy (mantener hasta confirmar que no se usan en producción).
    match /products/{id}    { allow read: if true; allow write: if isAdmin(); }
    match /categories/{id}  { allow read: if true; allow write: if isAdmin(); }

    // Fase 5: ofertas flash (lectura pública para la vitrina; escritura solo admin).
    match /flashOffers/{id} { allow read: if true; allow write: if isAdmin(); }

    // ── ENLACES ÚTILES (link-in-bio / LINKTREE) — NUEVO, NO DESPLEGAR AÚN ─────────
    // Páginas públicas de botones servidas en /l/{slug}. Lectura pública (la página
    // /l/{slug} lee 1 doc por slug); escritura SOLO admin (constructor en /admin/enlaces).
    // Las VISITAS (campo denormalizado 'visitas') y los CLICS por botón (subcolección
    // 'clics/{botonId}.count') se incrementan ÚNICAMENTE desde la Cloud Function
    // registrarClicEnlace (admin SDK, bypassa reglas). El cliente jamás escribe la
    // subcolección clics (write:false); el admin la LEE vía getClicsDeLinkPage
    // (read:true) para mostrar el conteo por botón en el editor.
    match /link_pages/{id} {
      allow read: if true;         // Vitrina pública de la página de enlaces.
      allow write: if isAdmin();   // Solo el admin crea/edita/borra páginas.

      // Contadores de clic por botón (id del doc = botonId). Lectura pública
      // (el admin los suma en el editor); solo la CF los incrementa.
      match /clics/{botonId} {
        allow read: if true;
        allow write: if false;
      }
    }

    // ── Gamificación / fidelización ──────────────────────────────────────────────
    match /globals/{id}            { allow read: if true;  allow write: if isAdmin(); } // activeChallenge
    match /weeklyChallenges/{id}   { allow read: if true;  allow write: if isAdmin(); }
    match /ruletaPrizes/{id}       { allow read: if true;  allow write: if isAdmin(); }
    match /wordle_daily_words/{id} { allow read: if true;  allow write: if isAdmin(); }

    // ── Fase 2: misiones diarias y libro mayor de fidelización ───────────────────
    // Config de misiones: lectura pública, escritura solo admin.
    match /missions/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Progreso diario por usuario (id '<uid>_<YYYY-MM-DD>'). Lo escribe el servidor
    // (getDailyMissionsSecure / completeMissionSecure vía admin SDK). El dueño solo lee.
    match /userMissions/{id} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }
    // Libro mayor de puntos (earn/spend). Solo el servidor escribe; el dueño lo lee.
    match /loyaltyLedger/{id} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    // ── Fase 2b: catálogo de recompensas y cupones canjeados ─────────────────────
    // Catálogo de recompensas: lectura pública (vitrina), escritura solo admin.
    match /rewardsCatalog/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Cupones del usuario: los crea SOLO el servidor (redeemRewardSecure vía admin
    // SDK); el dueño solo los lee. 'write' restringido a admin (Cloud Functions).
    match /userCoupons/{id} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow write: if isAdmin();
    }

    // Fase 3 — Marketplace multi-vendor.
    // subOrders: las crea el servidor (createOrderWithSubordersSecure); lee el comprador o admin.
    match /subOrders/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.buyerUid == request.auth.uid);
      allow write: if isAdmin();
    }
    match /shippingZones/{id} { allow read: if true; allow write: if isAdmin(); }
    match /payouts/{id} { allow read, write: if isAdmin(); }

    // Partidas de Wordle: lectura pública (ranking); el usuario solo escribe su registro.
    match /wordle/{id} {
      allow read: if true;
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // Evidencias de retos: se crean vía Cloud Function (admin SDK, evade reglas); el
    // cliente solo necesita leerlas como admin.
    match /challengeEvidences/{id} { allow read: if isAdmin(); allow write: if isAdmin(); }

    // Referidos: tracking que puede ocurrir SIN sesión (clic en el enlace). La
    // acreditación de monedas está protegida en el doc de usuario (no aquí).
    // TODO (H-05): mover claimReferralCoins a una Cloud Function y endurecer esto.
    match /referrals/{id} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // Eventos/fechas importantes del usuario (cumpleaños, aniversarios).
    // TODO: acotar por owner si los documentos llevan userId.
    match /organizable_events/{id} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() || isAdmin();
    }

    // ── Datos de usuario ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && sinSaldoEnCreate();
      allow update: if isAdmin() || (isOwner(userId) && noTocaCamposSensibles() && dniInmutable());
      allow delete: if isAdmin();
      match /notifications/{notifId} {
        allow read, update: if isOwner(userId) || isAdmin();
        allow create, delete: if isAdmin();
      }
    }
    match /portal_clientes_users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && sinSaldoEnCreate();
      allow update: if isAdmin() || (isOwner(userId) && noTocaCamposSensibles() && dniInmutable());
      allow delete: if isAdmin();
      match /notifications/{notifId} {
        allow read, update: if isOwner(userId) || isAdmin();
        allow create, delete: if isAdmin();
      }
    }

    match /orders/{orderId} {
      allow read: if isOwner(resource.data.userId)
                     || (isAuthenticated() && resource.data.buyerUid == request.auth.uid)
                     || isAdmin();
      allow create: if isAuthenticated() || request.resource.data.dni != null;
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ── ERP (proyecto compartido sistema-gestion-3b225) ──────────────────────────
    // Pedidos del ERP. El checkout web los crea SIN sesión, identificando con DNI.
    // Lectura: admin o el comprador autenticado dueño del pedido.
    match /pedidos/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.buyerUid == request.auth.uid);
      allow create: if isAuthenticated() || request.resource.data.dni != null;
      allow update, delete: if isAdmin();
    }
    match /pedidos_web/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.buyerUid == request.auth.uid);
      allow create: if isAuthenticated() || request.resource.data.dni != null;
      allow update: if isAdmin() || request.resource.data.dni != null;
      allow delete: if isAdmin();
    }

    match /designs/{designId} {
      allow read: if isOwner(resource.data.userId) || resource.data.isPublic == true || isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // Productos personalizados creados por el cliente (pre-compra).
    match /producto_cliente_personalizado/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() || isAdmin();
    }

    // Wishlists (doc id = uid). Lectura pública para compartir por enlace.
    match /wishlists/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    // Reseñas de productos. Lectura pública; crear autenticado; update permitido para
    // votos útiles. TODO: restringir update a solo 'helpfulVotes' con diff().
    match /product_reviews/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // ── Admin / configuración restringida ────────────────────────────────────────
    match /adminUsers/{userId} { allow read, write: if isAdmin(); }
    // adminRoles: el cliente autenticado lee su propio rol para computar permisos de UI.
    match /adminRoles/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /notification_settings/{id} { allow read, write: if isAdmin(); }
    match /storeConfigLogs/{id}       { allow read, write: if isAdmin(); }
    match /inventoryLogs/{id}         { allow read, write: if isAdmin(); }
    // (regla fantasma 'analytics_kapi' eliminada: ninguna parte del código la usa;
    //  la analítica real vive en las colecciones analytics_* de abajo)
    // Lock de dedup de referidos (H-05): solo lo escribe Cloud Functions (admin SDK).
    match /referralOrderClaims/{id}   { allow read, write: if isAdmin(); }

    // ── Analítica (proyecto compartido) ──────────────────────────────────────────
    // Ingesta pública/anónima desde el cliente; la lectura/gestión queda solo a admin.
    match /analytics_events/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /analytics_sessions/{id} {
      allow create: if true;
      allow update: if true;
      allow read, delete: if isAdmin();
    }
    match /analytics_user_summary/{id}   { allow read, write: if isAdmin(); }
    match /analytics_global_summary/{id} { allow read, write: if isAdmin(); }
    // Agregado diario pre-computado (CF aggregateAnalyticsDaily escribe con Admin
    // SDK y bypassa rules); el dashboard admin lo lee directo. Sin esta regla,
    // desplegar rules mataría en silencio la vía barata del dashboard (P1).
    match /analytics_daily/{id} { allow read: if isAdmin(); allow write: if false; }

    // ── Ingestión pública controlada ─────────────────────────────────────────────
    match /heatmap_events/{eventId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
    match /libro_reclamaciones/{reclamoId} {
      allow create: if true;             // Formulario público de reclamaciones (INDECOPI)
      allow read, update, delete: if isAdmin();
    }
    match /enlaces_pago/{enlaceId} {
      allow read: if true;               // Público para quien tiene el link (id no adivinable)
      allow create: if isAdmin();
      allow update, delete: if isAdmin(); // H-08: antes era 'if true' (fraude/DoS)
    }

    // ── MÓDULO SORTEOS (NUEVO — server-authoritative) ────────────────────────────
    // La página de sorteos es pública (lectura del doc + contador). La participación
    // NO se escribe desde el cliente: pasa por la Cloud Function participarSorteoGratis
    // (admin SDK, bypassa estas reglas). Por eso todas las subcolecciones son
    // write:false para el cliente. Los admin gestionan el catálogo de sorteos.
    match /sorteos/{id} {
      allow read: if true;               // Vitrina pública del sorteo.
      allow write: if isAdmin();         // Solo el admin crea/edita/cierra sorteos.

      // Participantes: los crea SOLO la Cloud Function. El cliente autenticado puede
      // leer (p. ej. para verificar su propia participación); nunca escribe.
      match /participantes/{uid} {
        allow read: if isAuthenticated();
        allow write: if false;
      }
      // Contador con shards: lectura pública (la página suma los shards); solo la CF escribe.
      match /contador/{shardId} {
        allow read: if true;
        allow write: if false;
      }
      // Tickets y sorteos realizados (builds futuros): solo el admin lee; solo la CF escribe.
      match /tickets/{ticketId} {
        allow read: if isAdmin();
        allow write: if false;
      }
      match /sorteos_realizados/{realizadoId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }
  }
}
